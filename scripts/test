#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: scripts/test [--arch cdna3|cdna4|udna1] <target> [make args...]

Targets:
  kernels          Build and run kernel tests under variants/rocm_<arch>
  all              Alias for kernels
  tests            Build and run primitive tests for the selected arch
  tests-cdna3      Build and run CDNA3 primitive tests
  tests-cdna4      Build and run CDNA4 primitive tests
  tests-udna1      Build and run UDNA1 primitive tests
  <path>           Build and run tests in a kernel directory or subtree

Set PYTHON=/path/to/python to choose the Python used for pybind tests.
Archives are never included in kernel discovery.
USAGE
}

arch=""
target=""
make_args=()
PYTHON="${PYTHON:-python3}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help|help)
      usage
      exit 0
      ;;
    --arch)
      if [ "$#" -lt 2 ]; then
        echo "--arch requires a value" >&2
        exit 2
      fi
      arch="$2"
      shift 2
      ;;
    --arch=*)
      arch="${1#--arch=}"
      shift
      ;;
    *)
      if [ -z "${target}" ]; then
        target="$1"
      else
        make_args+=("$1")
      fi
      shift
      ;;
  esac
done

if [ -z "${target}" ]; then
  usage
  exit 0
fi

for arg in "${make_args[@]}"; do
  case "${arg}" in
    [A-Za-z_]*=*)
      export "${arg}"
      ;;
  esac
done

lower() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

normalize_arch() {
  local raw
  raw="$(lower "$1")"
  case "${raw}" in
    cdna2|rocm_cdna2|gfx90a)
      echo "cdna2"
      ;;
    cdna3|rocm_cdna3|gfx940|gfx941|gfx942)
      echo "cdna3"
      ;;
    cdna4|rocm_cdna4|gfx950|mi350x|mi355x)
      echo "cdna4"
      ;;
    udna1|rocm_udna1|gfx1250)
      echo "udna1"
      ;;
    *)
      echo "${raw}"
      ;;
  esac
}

detect_arch() {
  local gfx=""
  if command -v rocminfo >/dev/null 2>&1; then
    gfx="$(rocminfo 2>/dev/null | awk '/Name:[[:space:]]+gfx[[:alnum:]]+/ {print $2; exit}')"
  fi

  if [ -n "${gfx}" ]; then
    normalize_arch "${gfx}"
  else
    echo "cdna3"
  fi
}

arch_from_path() {
  case "$1" in
    *variants/rocm_cdna2*) echo "cdna2" ;;
    *variants/rocm_cdna3*) echo "cdna3" ;;
    *variants/rocm_cdna4*) echo "cdna4" ;;
    *variants/rocm_udna1*) echo "udna1" ;;
    *) return 1 ;;
  esac
}

resolve_arch() {
  local path="${1:-}"
  if [ -n "${arch}" ]; then
    normalize_arch "${arch}"
  elif [ -n "${path}" ] && arch_from_path "${path}" >/dev/null 2>&1; then
    arch_from_path "${path}"
  else
    detect_arch
  fi
}

gpu_target() {
  case "$1" in
    cdna3) echo "CDNA3" ;;
    cdna4) echo "CDNA4" ;;
    udna1) echo "UDNA1" ;;
    *)
      echo "Unsupported test arch '$1'. Supported: cdna3, cdna4, udna1" >&2
      exit 2
      ;;
  esac
}

variant_prefix() {
  case "$1" in
    cdna3) echo "rocm_cdna3" ;;
    cdna4) echo "rocm_cdna4" ;;
    udna1) echo "rocm_udna1" ;;
    *)
      echo "Unsupported test arch '$1'. Supported: cdna3, cdna4, udna1" >&2
      exit 2
      ;;
  esac
}

find_kernel_tests() {
  local root="$1"
  local selected_arch="$2"
  local variant
  variant="$(variant_prefix "${selected_arch}")"
  # Discover both python test scripts AND standalone-harness Makefiles (many
  # CDNA3 ports ship a self-checking `make test` harness with no test_python.py).
  # Print one path per test directory; run_test_dir figures out what to run.
  find "${root}" \
    -path '*/archive/*' -prune -o \
    -type f -path "*/variants/${variant}*/*" \
    \( -name test_python.py -o -name test.py -o -name test_gemm.py -o -name Makefile \) \
    -print | sort -u
}

# True if the Makefile in $1 defines target $2 (grep the .PHONY line or a rule).
makefile_has_target() {
  local dir="$1" tgt="$2"
  [ -f "${dir}/Makefile" ] || return 1
  grep -qE "^${tgt}:" "${dir}/Makefile" || grep -qE "^\.PHONY:.*\b${tgt}\b" "${dir}/Makefile"
}

run_test_dir() {
  local dir="$1"
  local selected_arch="$2"
  local gpu
  local tests=()
  local script
  gpu="$(gpu_target "${selected_arch}")"

  [ -f "${dir}/test_python.py" ] && tests+=("test_python.py")
  [ -f "${dir}/test.py" ] && tests+=("test.py")
  [ -f "${dir}/test_gemm.py" ] && tests+=("test_gemm.py")

  if [ "${#tests[@]}" -gt 0 ]; then
    echo "==> ${dir}"
    make -C "${dir}" "GPU_TARGET=${gpu}" "PYTHON=${PYTHON}" "${make_args[@]}"
    for script in "${tests[@]}"; do
      echo "    ${script}"
      (cd "${dir}" && "${PYTHON}" "${script}")
    done
    return 0
  fi

  # No python test scripts: fall back to a standalone-harness `make test`.
  if makefile_has_target "${dir}" test; then
    echo "==> ${dir} (make test)"
    make -C "${dir}" "GPU_TARGET=${gpu}" "PYTHON=${PYTHON}" test "${make_args[@]}"
  fi
  return 0
}

run_kernel_tree() {
  local root="$1"
  local selected_arch
  local last_dir=""
  local test_file dir
  selected_arch="$(resolve_arch "${root}")"

  mapfile -t test_files < <(find_kernel_tests "${root}" "${selected_arch}")
  if [ "${#test_files[@]}" -eq 0 ]; then
    echo "No kernel tests found for arch '${selected_arch}'" >&2
    exit 1
  fi

  for test_file in "${test_files[@]}"; do
    dir="${test_file%/*}"
    if [ "${dir}" != "${last_dir}" ]; then
      run_test_dir "${dir}" "${selected_arch}"
      last_dir="${dir}"
    fi
  done
}

run_path() {
  local path="$1"
  local selected_arch
  selected_arch="$(resolve_arch "${path}")"

  if [ -f "${path}/Makefile" ]; then
    run_test_dir "${path}" "${selected_arch}"
  else
    run_kernel_tree "${path}"
  fi
}

run_unit_tests_for_arch() {
  local selected_arch="$1"
  case "${selected_arch}" in
    cdna3)
      make -C tests/unit/cdna4 GPU_TARGET=CDNA3 run "${make_args[@]}"
      ;;
    cdna4)
      make -C tests/unit/cdna4 GPU_TARGET=CDNA4 run "${make_args[@]}"
      ;;
    udna1)
      make -C tests/unit/udna1 GPU_TARGET=UDNA1 run "${make_args[@]}"
      ;;
    *)
      echo "Unsupported unit-test arch '${selected_arch}'" >&2
      exit 2
      ;;
  esac
}

case "${target}" in
  kernels|all)
    run_kernel_tree "kernels"
    ;;
  tests)
    run_unit_tests_for_arch "$(resolve_arch)"
    ;;
  tests-cdna3)
    arch="cdna3"
    run_unit_tests_for_arch "cdna3"
    ;;
  tests-cdna4)
    arch="cdna4"
    run_unit_tests_for_arch "cdna4"
    ;;
  tests-udna1)
    arch="udna1"
    run_unit_tests_for_arch "udna1"
    ;;
  *)
    if [ -d "${target}" ]; then
      run_path "${target}"
    elif [ -d "kernels/${target}" ]; then
      run_path "kernels/${target}"
    else
      echo "Unknown test target: ${target}" >&2
      exit 2
    fi
    ;;
esac
